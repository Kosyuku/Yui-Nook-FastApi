# Pyro-Gemini 环境变量配置

# ═══ 基础 ═══
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=./data/gateway.db
CORS_ALLOW_ORIGINS=*
INTERNAL_API_TOKEN=

# ═══ 记忆存储后端 ═══
# sqlite | supabase
DATABASE_BACKEND=sqlite
MEMORY_BACKEND=sqlite
DEFAULT_AGENT_ID=azheng
CURRENT_AGENT_ID=azheng
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SESSIONS_TABLE=sessions
SUPABASE_MESSAGES_TABLE=messages
SUPABASE_MEMORIES_TABLE=memories
SUPABASE_DIARY_TABLE=diary
SUPABASE_DIARY_NOTEBOOKS_TABLE=diary_notebooks
SUPABASE_DIARY_ENTRIES_TABLE=diary_entries
SUPABASE_DIARY_COMMENTS_TABLE=diary_comments
SUPABASE_DIARY_ANNOTATIONS_TABLE=diary_annotations
SUPABASE_CONTEXT_SUMMARIES_TABLE=context_summaries
SUPABASE_TODOS_TABLE=todos
SUPABASE_NOTES_TABLE=notes
SUPABASE_PROACTIVE_MESSAGES_TABLE=proactive_messages
SUPABASE_ACTIVITY_EVENTS_TABLE=activity_events
SUPABASE_MEMORY_LOGS_TABLE=memory_logs
SUPABASE_SETTINGS_TABLE=app_settings
SUPABASE_MEDIA_ITEMS_TABLE=media_items
# 0=直连 Supabase（忽略系统代理，推荐）；1=使用 HTTP_PROXY
SUPABASE_HTTP_TRUST_ENV=0

# ======= Media library: Cloudflare R2 stores file bodies; DB stores metadata only =======
MEDIA_STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yui-media
R2_ENDPOINT=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=3600

# ═══ 聊天模型 ═══
CHAT_PROVIDER=echo
CHAT_BASE_URL=
CHAT_API_KEY=
CHAT_MODEL=

# ═══ 总结模型 (可用便宜模型) ═══
SUMMARY_PROVIDER=echo
SUMMARY_BASE_URL=
SUMMARY_API_KEY=
SUMMARY_MODEL=

# 钰愨晲钰?Embeddings / 向量记忆检索 钰愨晲钰?
# 默认可复用 CHAT_BASE_URL / CHAT_API_KEY，只需额外提供 embedding 模型名
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
SUPABASE_MEMORY_MATCH_RPC=match_memories

# ═══ 人设 ═══
PERSONA_NAME=Pyro
PERSONA_DESCRIPTION=

# ═══ 天气 (OpenWeatherMap) ═══
WEATHER_API_KEY=
DEFAULT_CITY=Shanghai

# ═══ Web 搜索 ═══
SEARCH_ENGINE=searxng
SEARCH_API_KEY=
SEARXNG_URL=

# ═══ 意识循环 ═══
CONSCIOUSNESS_ENABLED=true
CONSCIOUSNESS_INTERVAL_HOURS=2.5
PROACTIVE_MAX_DAILY=5
PROACTIVE_QUIET_START=23
PROACTIVE_QUIET_END=7

# ═══ Token / Prompt 预算 ═══
CHAT_RECENT_MESSAGES_LIMIT=12
TOOL_RESULT_MAX_CHARS=1200
PROMPT_MEMORY_ITEMS=5
PROMPT_MEMORY_ITEM_MAX_CHARS=180
PROMPT_SUMMARY_ITEMS=2
PROMPT_SUMMARY_ITEM_MAX_CHARS=260
PROMPT_TOOL_COUNT_MAX=8
PROMPT_TOOL_DESC_MAX_CHARS=80

# ═══ 上下文摘要触发策略 ═══
SUMMARY_TRIGGER_MESSAGES=24
SUMMARY_KEEP_RECENT_MESSAGES=12
SUMMARY_MIN_BATCH_MESSAGES=8

# ═══ 工具调用稳定性 ═══
TOOL_TIMEOUT_SECONDS=15
TOOL_RETRY_COUNT=1
TOOL_LOG_MAX_RESULT_CHARS=200

# ═══ 记忆治理 v1 ═══
MEMORY_AUTO_EXTRACT_ENABLED=true
MEMORY_AUTO_EXTRACT_MIN_CHARS=8
MEMORY_AUTO_EXTRACT_MAX_CHARS=220
MEMORY_RETRIEVAL_TOP_K=6
MEMORY_RETRIEVAL_KEYWORD_COUNT=4
MEMORY_VECTOR_ENABLED=true
MEMORY_VECTOR_CANDIDATE_LIMIT=200
MEMORY_ASYNC_ENABLED=true
MEMORY_ASYNC_STARTUP_BACKFILL_LIMIT=50

# ═══ 生产模式开关（建议生产设为 false） ═══
ALLOW_CLIENT_PROVIDER_OVERRIDE=true

# ======= [Optional] MCP Remote Server =======
# 配置 HTTP 远程连接 MCP Server 所需环境变量
# 指定运行的端口（默认8001）
# MCP_PORT=8001
# 配置 API 访问鉴权密钥 (需在 Claude Remote 配置对应的 Bearer token)
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_PUBLIC_BASE_URL=
OAUTH_ISSUER=
OAUTH_SESSION_SECRET=
OAUTH_ADMIN_USERNAME=admin
OAUTH_ADMIN_PASSWORD_HASH=
OAUTH_CLIENT_ID=claude-mcp
OAUTH_CLIENT_SECRET=
OAUTH_CLIENT_NAME=Claude MCP Connector
OAUTH_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback
OAUTH_DEFAULT_SCOPE=mcp
OAUTH_AUTH_CODE_TTL_SECONDS=600
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
